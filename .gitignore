#ignore results and generated data 
#data/*
#results/*

#unignore raw data (should never change other than adding files as needed)
!data/raw/

#ignore testing files
temp/*

# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

#output files
*.png
*.jpg
*.csv
*.xls
*.xlsx
*.rds

# Mark Output files
*.inp
*.Rinp
*.out
*.res
*.vcv
*.tmp

#ignore generated report documents
*.docx